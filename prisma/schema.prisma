generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int       @id @default(autoincrement())
  namaToko   String
  email      String    @unique
  password   String
  noWhatsapp String?
  alamat     String?
  fotoToko   String    @default("default-store.png")
  createdAt  DateTime  @default(now())
  products   Product[]
  orders     Order[]
}

model Product {
  id        Int       @id @default(autoincrement())
  userId    Int
  foto      String
  nama      String
  harga     Float
  stok      Int       @default(0)
  deskripsi String?
  kategori  String?
  status    String    @default("active")
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
}

model Order {
  id            Int       @id @default(autoincrement())
  productId     Int
  userId        Int
  pembeliNama   String
  pembeliAlamat String?
  pembeliNoHp   String?
  jumlah        Int       @default(1)
  totalHarga    Float
  status        String    @default("pending")
  paymentMethod String    @default("qris")
  paymentStatus String    @default("unpaid")
  orderCode     String    @unique
  snapToken     String?
  createdAt     DateTime  @default(now())
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
